{
  "name": "@rturv/mcp-pdf-reader",
  "version": "1.0.0",
  "description": "A Model Context Protocol (MCP) server that enables AI assistants (Claude, GitHub Copilot) to read, extract text, search, and analyze PDF files with full metadata and image extraction support",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-pdf-reader": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pdf",
    "pdf-reader",
    "pdf-extraction",
    "text-extraction",
    "metadata-extraction",
    "image-extraction",
    "pdf-search",
    "claude",
    "github-copilot",
    "ai-assistant",
    "anthropic",
    "tool"
  ],
  "author": "rturv",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rturv/mcp-pdf-reader.git"
  },
  "bugs": {
    "url": "https://github.com/rturv/mcp-pdf-reader/issues"
  },
  "homepage": "https://github.com/rturv/mcp-pdf-reader#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.8",
    "@types/pdf-parse": "^1.1.4",
    "@types/pdfkit": "^0.17.4",
    "jest": "^29.7.0",
    "pdfkit": "^0.17.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
