{
  "name": "mcp-pdf-reader",
  "version": "1.0.0",
  "description": "MCP Server for reading and extracting information from PDF files",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-pdf-reader": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "pdf",
    "reader",
    "model-context-protocol"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.8",
    "@types/pdf-parse": "^1.1.4",
    "@types/pdfkit": "^0.17.4",
    "jest": "^29.7.0",
    "pdfkit": "^0.17.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
